{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Markive",
  "version": "0.1.0",
  "identifier": "codes.darius.markive",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "create": false,
        "title": "Markive",
        "width": 1180,
        "height": 760,
        "minWidth": 720,
        "minHeight": 480,
        "center": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": []
      }
    }
  },
  "bundle": {
    "active": false
  }
}
